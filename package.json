{
  "name": "oop-emr",
  "version": "1.0.0",
  "description": "Mock trauma EMR with a public ingest endpoint. Prehospital AI systems POST JSON payloads and the clinical UI populates in real time.",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "demo": "node scripts/demo.js",
    "demo:prod": "BASE_URL=https://oop-emr.vercel.app GAP_MS=10000 node --env-file=.env.local scripts/demo.js"
  },
  "engines": {
    "node": ">=20.6"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  }
}
