# Copy to .env for local dev. Without Upstash credentials the server falls back
# to an in-memory store — fine for a single-process local demo, but state will
# NOT survive across Vercel serverless invocations, so set these in production.

# REST endpoint (writes, reads) — used by every handler except SSE
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# TCP endpoint (pub/sub SUBSCRIBE) — only used by /api/events
# Looks like rediss://default:<password>@<host>:<port>
UPSTASH_REDIS_URL=

# Leave blank to disable x-api-key auth on /api/encounter and /api/demo-reset
API_KEY=
